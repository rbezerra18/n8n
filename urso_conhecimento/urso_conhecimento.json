    {
      "parameters": {
        "jsCode": "// 1. Pega todos os dados que vieram do Redis\nconst allItems = $input.all();\nlet results = [];\n\nfor (const item of allItems) {\n  // Pega a string de IDs (\"id1,id2...\")\n  const values = Object.values(item.json);\n  const keysStr = values.length > 0 ? values[0] : '';\n  \n  if (keysStr && typeof keysStr === 'string' && keysStr.trim() !== '') {\n    // Quebra a string e gera um novo item para cada ID\n    const chunks = keysStr.split(',').map(id => ({\n      json: { keyToDelete: id.trim() }\n    }));\n    results = results.concat(chunks);\n  }\n}\n\nreturn results;"
      },
