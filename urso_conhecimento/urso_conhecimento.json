        "jsCode": "const pre = new Set($node[\"Redis (Pré-Scan)\"].json.keys || []);\nconst post = $node[\"Redis (Pós-Scan)\"].json.keys || [];\nconst fileName = $node[\"Padronizar Dados\"].json.fileName;\nconst diff = post.filter(k => !pre.has(k));\nreturn { fileName, ids: diff.join(',') };"
