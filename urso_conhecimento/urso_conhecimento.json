    {
      "parameters": {
        "jsCode": "// 1. Pega os nomes dos arquivos que estão no Drive agora\nconst driveFiles = $(\"Arquivos Deletados\").all().map(i => i.json.name);\n\n// 2. Pega a lista de chaves que o Redis retornou\nconst redisKeys = $(\"Redis (Listar Index)\").first().json.keys || [];\n\n// 3. Formata as chaves do Redis para comparação e extrai o nome\nconst redisIndices = redisKeys.map(key => {\n  return {\n    key: key,\n    fileName: key.replace(\"doc:idx:\", \"\")\n  }\n});\n\n// 4. Filtra quem está no Redis mas NÃO está mais no Drive\nconst orphans = redisIndices.filter(index => !driveFiles.includes(index.fileName));\n\nreturn orphans;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
