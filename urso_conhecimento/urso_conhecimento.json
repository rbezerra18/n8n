    {
      "parameters": {
        "jsCode": "// Normaliza o conteúdo da planilha para texto\nconst fileName = $(\"Padronizar Dados\").first().json.fileName;\nconst type = $(\"Padronizar Dados\").first().json.mimeType;\n\nreturn $input.all().map(item => {\n  const rowText = Object.keys(item.json)\n    .map(key => `${key}: ${item.json[key] || ''}`)\n    .join(' | ');\n  return {\n    json: {\n      text: rowText,\n      source: fileName,\n      tipo: type\n    }\n  };\n});"
      },
