    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const event = $json;\n\n// ===== CONFIGURAÇÃO =====\n// coloque aqui o USER ID do seu bot (não é o App ID)\nconst BOT_USER_ID = \"U0AD9DZ1GJ3\"; // ← troque se necessário\n\n// ========================\n\n// texto original vindo do Slack\nconst rawText = event.text || \"\";\n\n// texto limpo (remove menções)\nconst cleanText = rawText\n  .replace(/<@[^>]+>/g, \"\")\n  .replace(/\\u200B|\\u00A0/g, \" \") // remove caracteres invisíveis do Slack\n  .trim();\n\nconst eventId =\n  event.client_msg_id ||\n  `${event.channel}-${event.ts}`;\n\n// Inside the Code node (lines 425-512)\nconst isDM = (event.channel_type === \"im\") || (event.channel && event.channel.startsWith(\"D\"));\n\n// ===== DETECÇÕES =====\n\n// mensagem enviada por bot?\nconst isBotMessage =\n  !!event.bot_id ||\n  event.subtype === \"bot_message\" ||\n  event.user === BOT_USER_ID;\n\n// evento inválido (edição, deleção, etc)\nconst isIgnoredSubtype =\n  event.subtype === \"message_changed\" ||\n  event.subtype === \"message_deleted\";\n\n// resposta dentro de thread?\nconst isThreadReply = !!event.thread_ts;\n\n// menção ao bot?\nconst hasMention = rawText.includes(`<@${BOT_USER_ID}>`);\n\n// evento é menção oficial do Slack?\nconst isAppMention = event.type === \"app_mention\";\n\nconst isThreadFromBot =\n  !!event.thread_ts &&\n  event.parent_user_id === BOT_USER_ID;\n\n// ========================\n\nreturn {\n  json: {\n    // identificação\n    channel: event.channel,\n    user: event.user,\n    event_id: eventId,\n\n    // texto\n    raw_text: rawText,\n    text: cleanText,\n\n    // timestamps\n    ts: event.ts,\n    thread_ts: event.thread_ts || null,\n\n    // tipo de canal/evento\n    channel_type: event.channel_type || null,\n    event_type: event.type || null,\n    subtype: event.subtype || null,\n\n    // flags inteligentes (🔥 importante)\n    is_bot_message: isBotMessage,\n    is_ignored_event: isIgnoredSubtype,\n    is_thread_reply: isThreadReply,\n    is_thread_from_bot: isThreadFromBot,\n    is_app_mention: isAppMention,\n    is_dm: isDM,\n    has_mention: hasMention,\n    \n    // debug útil\n    bot_id: event.bot_id || null,\n    parent_user_id: event.parent_user_id || null\n  }\n};"
      },
