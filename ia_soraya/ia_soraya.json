    {
      "parameters": {
        "jsCode": "const msg = $(\"Telegram Trigger\").first().json.message;\n\nlet route = \"unknown\";\nlet file_id = null;\nlet text = \"\";\n\n// TEXTO\nif (msg.text) {\n  route = \"text\";\n  text = msg.text;\n}\n\n// FOTO\nif (msg.photo) {\n  route = \"image\";\n  file_id = msg.photo[msg.photo.length - 1].file_id;\n  text = msg.caption || \"\";\n}\n\n// ÁUDIO (voice message)\nif (msg.voice) {\n  route = \"voice\";\n  file_id = msg.voice.file_id;\n}\n\n// DOCUMENTO\nif (msg.document) {\n  route = \"document\";\n  file_id = msg.document.file_id;\n  text = msg.caption || \"\";\n}\n\n// MULTIMODAL (foto + texto)\nif (msg.photo && msg.caption) {\n  route = \"multimodal\";\n}\n\nreturn [\n  {\n    json: {\n      route,\n      file_id,\n      text,\n      chat_id: msg.chat.id,\n      user_id: msg.from.id\n    }\n  }\n];"
      },
