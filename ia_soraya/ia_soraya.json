    {
      "parameters": {
        "jsCode": "let finalText = $json.text || \"\";\n\n// áudio\ntry {\n  const audio = $(\"Audio\").first().json.text;\n  if (audio) finalText += \"\\n\\nÁudio: \" + audio;\n} catch {}\n\n// imagem\ntry {\n  const img = $(\"Image\").first().json.text;\n  if (img) finalText += \"\\n\\nImagem: \" + img;\n} catch {}\n\n// PDF\ntry {\n  const pdf = $(\"Extract From File\").first().json.text;\n  if (pdf) finalText += \"\\n\\nConteúdo do documento:\\n\" + pdf;\n} catch {}\n\nreturn [\n  {\n    json: {\n      text: finalText\n    }\n  }\n];"
      },
