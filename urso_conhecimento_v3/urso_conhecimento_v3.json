    {
      "parameters": {
        "jsCode": "/*\nCaptura os IDs gerados pelo Vector Store.\nNo n8n-langchain, o output costuma vir como documentos.\nPrecisamos salvar o mapping para limpeza futura.\n*/\nconst items = $input.all();\nconst fileName = $(\"Padronizar Dados\").first().json.fileName;\n\n// Nota: O nó do Redis Vector Store no n8n retorna os documentos processados.\n// Vamos extrair as chaves que foram criadas no Redis.\nconst redisKeys = items.map(item => item.json.metadata.id || item.json.id).filter(id => id);\n\nreturn {\n  fileName: fileName,\n  ids: redisKeys.join(',')\n};"
      },
