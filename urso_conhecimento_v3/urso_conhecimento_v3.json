    {
      "parameters": {
        "jsCode": "// Formatação robusta para GSheets\nconst fileName = $(\"Padronizar Dados\").first().json.fileName;\nconst type = $(\"Padronizar Dados\").first().json.mimeType;\n\nreturn $input.all().map(item => {\n  const rowText = Object.keys(item.json)\n    .map(key => `${key}: ${item.json[key] || ''}`)\n    .join(' | ');\n  return {\n    json: {\n      content: rowText,\n      source: fileName,\n      tipo: type\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
